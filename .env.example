# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=ITSM_ITIL_V4
APP_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_URL=http://localhost:3000
API_PREFIX=api/v1
API_VERSION=1

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=itsm_db
DB_SCHEMA=public
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_POOL_MAX=10
DB_POOL_MIN=2

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@itsm.com
MAIL_FROM_NAME=ITSM System

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,txt,zip

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
BCRYPT_SALT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# FE Next.js dev mặc định :3001 — bổ sung thêm origin khác nếu cần (không có khoảng trắng sau dấu phẩy)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4200

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=30d
LOG_MAX_SIZE=20m

# =============================================================================
# ITSM SPECIFIC CONFIGURATION
# =============================================================================
# SLA Business Hours (HH:mm)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=17:30
BUSINESS_TIMEZONE=Asia/Ho_Chi_Minh

# Ticket Number Prefix
INCIDENT_PREFIX=INC
PROBLEM_PREFIX=PRB
CHANGE_PREFIX=CHG
REQUEST_PREFIX=REQ
RELEASE_PREFIX=REL

# Auto-assignment
AUTO_ASSIGN_ENABLED=true
ESCALATION_ENABLED=true

# Integration
CMDB_SYNC_INTERVAL=3600000

# Queue Configuration
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379

# =============================================================================
# SYSTEM MONITOR CONFIGURATION
# =============================================================================
METRICS_RETENTION_DAYS=7
METRICS_CPU_ALERT_THRESHOLD=80
METRICS_MEMORY_ALERT_THRESHOLD=85
